---
layout: false
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>江南字栈 | 内容管理</title>
    <link rel="stylesheet" href="/admin/admin.css" />
    <style>
      :root {
        color-scheme: dark;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top, rgba(111, 141, 135, 0.16), transparent 30%),
          linear-gradient(180deg, #0c1417 0%, #132127 45%, #0c1316 100%);
        color: #e9eadf;
        font-family: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
        overflow: hidden;
      }

      .cms-shell {
        display: grid;
        grid-template-rows: auto 1fr;
        min-height: 100vh;
      }

      .cms-banner {
        align-items: center;
        backdrop-filter: blur(12px);
        background: rgba(7, 13, 16, 0.72);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        gap: 16px;
        justify-content: space-between;
        padding: 14px 22px;
      }

      .cms-brand {
        align-items: center;
        display: flex;
        gap: 14px;
      }

      .cms-seal {
        background: linear-gradient(180deg, #932617, #6f1c13);
        border: 1px solid rgba(255, 236, 218, 0.16);
        border-radius: 10px;
        color: #fff1e5;
        font-size: 13px;
        letter-spacing: 0.3em;
        padding: 8px 10px 8px 14px;
      }

      .cms-title {
        display: grid;
        gap: 4px;
      }

      .cms-title strong {
        font-size: 16px;
        font-weight: 600;
        letter-spacing: 0.18em;
      }

      .cms-title span {
        color: rgba(233, 234, 223, 0.7);
        font-size: 12px;
        letter-spacing: 0.12em;
      }

      .cms-note {
        color: rgba(233, 234, 223, 0.72);
        font-size: 12px;
        letter-spacing: 0.06em;
      }

      #nc-root {
        min-height: 0;
        overflow: auto;
      }
    </style>
    <script defer src="https://unpkg.com/decap-cms@^3.10.1/dist/decap-cms.js"></script>
    <script>
      (() => {
        const OFFSET_ATTR = "data-cms-offset-applied";
        const SITE_TEXT = "TIAN3379.github.io";

        function normalizeText(value) {
          return (value || "").replace(/\s+/g, "");
        }

        function getClickableText(el) {
          if (!el) return "";
          return normalizeText(el.textContent || el.innerText || "");
        }

        function findByExactText(root, text) {
          const target = normalizeText(text);
          return [...root.querySelectorAll("button, a, [role='button'], [role='tab'], [tabindex]")]
            .find(el => getClickableText(el) === target) || null;
        }

        function isTopOverlay(el) {
          const style = window.getComputedStyle(el);
          const rect = el.getBoundingClientRect();
          if (style.display === "none" || style.visibility === "hidden") return false;
          if (!["fixed", "sticky"].includes(style.position)) return false;
          if (rect.top > 4 || rect.height < 36 || rect.height > 180) return false;
          if (rect.width < window.innerWidth * 0.35) return false;
          return true;
        }

        function visibleOverlays() {
          return [...document.body.querySelectorAll("*")].filter(isTopOverlay);
        }

        function findToolbarContainer(el) {
          let current = el;
          while (current && current !== document.body) {
            const rect = current.getBoundingClientRect();
            const style = window.getComputedStyle(current);
            if (style.display !== "none" &&
                rect.width > window.innerWidth * 0.35 &&
                rect.height >= 40 &&
                current.children.length >= 2) {
              return current;
            }
            current = current.parentElement;
          }
          return el?.parentElement || null;
        }

        function findHostRow(primaryToolbar) {
          const rows = [primaryToolbar, ...primaryToolbar.querySelectorAll("*")];
          let best = null;
          for (const row of rows) {
            const rect = row.getBoundingClientRect();
            const style = window.getComputedStyle(row);
            if (style.display === "none") continue;
            if (rect.width < window.innerWidth * 0.35 || rect.height < 28 || rect.height > 120) continue;
            const text = normalizeText(row.textContent || "");
            if (text.includes("已发布") || text.includes("删除内容")) {
              best = row;
              break;
            }
          }
          return best || primaryToolbar;
        }

        function findMovableNode(el, stopAt) {
          let current = el;
          while (current && current !== stopAt && current.parentElement) {
            const parent = current.parentElement;
            if (parent === stopAt) return current;
            if (parent.children.length > 1) return current;
            current = parent;
          }
          return el;
        }

        function ensureHostWrap(hostRow) {
          let wrap = hostRow.querySelector('[data-cms-host-wrap="true"]');
          if (wrap) return wrap;
          wrap = document.createElement("div");
          wrap.setAttribute("data-cms-host-wrap", "true");
          wrap.style.display = "flex";
          wrap.style.alignItems = "center";
          wrap.style.gap = "14px";
          wrap.style.flexWrap = "wrap";
          hostRow.appendChild(wrap);
          return wrap;
        }

        function moveControlsIntoPrimaryRow(root) {
          const published = findByExactText(root, "已发布");
          if (!published) return;

          const primaryToolbar = findToolbarContainer(published);
          if (!primaryToolbar) return;

          const hostRow = findHostRow(primaryToolbar);
          const hostWrap = ensureHostWrap(hostRow);
          hostRow.style.display = "flex";
          hostRow.style.alignItems = "center";
          hostRow.style.justifyContent = "space-between";
          hostRow.style.gap = "16px";
          hostRow.style.flexWrap = "wrap";

          ["内容", "媒体", "快速新建"].forEach(label => {
            const control = findByExactText(root, label);
            if (!control) return;
            const node = findMovableNode(control, control.closest("body"));
            if (!node || hostWrap.contains(node) || hostRow.contains(node) && node !== control) return;
            hostWrap.appendChild(node);
          });
        }

        function hideSecondaryIdentity(root) {
          const overlays = visibleOverlays();
          overlays.forEach(overlay => {
            const text = normalizeText(overlay.textContent || "");
            if (!text.includes(normalizeText(SITE_TEXT))) return;
            overlay.querySelectorAll("*").forEach(node => {
              const nodeText = normalizeText(node.textContent || "");
              if (nodeText.includes(normalizeText(SITE_TEXT))) {
                const removable = findMovableNode(node, overlay) || node;
                removable.style.display = "none";
              }
            });

            overlay.querySelectorAll("img, svg").forEach(node => {
              const rect = node.getBoundingClientRect();
              if (rect.width >= 20 && rect.height >= 20) {
                const removable = findMovableNode(node, overlay) || node;
                removable.style.display = "none";
              }
            });
          });
        }

        function findContentContainer(root, overlayBottom) {
          const direct = [...root.children];
          const directCandidate = direct.find(el => {
            const rect = el.getBoundingClientRect();
            const style = window.getComputedStyle(el);
            return style.display !== "none" &&
              !["fixed", "sticky"].includes(style.position) &&
              rect.height > window.innerHeight * 0.55 &&
              rect.width > window.innerWidth * 0.45;
          });
          if (directCandidate) return directCandidate;

          const all = [...root.querySelectorAll("*")];
          const candidates = all.filter(el => {
            const rect = el.getBoundingClientRect();
            const style = window.getComputedStyle(el);
            return style.display !== "none" &&
              !["fixed", "sticky"].includes(style.position) &&
              rect.top < overlayBottom + 12 &&
              rect.height > window.innerHeight * 0.5 &&
              rect.width > window.innerWidth * 0.45;
          });

          candidates.sort((a, b) => b.getBoundingClientRect().height - a.getBoundingClientRect().height);
          return candidates[0] || null;
        }

        function applyCmsOffset() {
          const root = document.getElementById("nc-root");
          if (!root) return;

          moveControlsIntoPrimaryRow(root);
          hideSecondaryIdentity(root);

          const overlays = visibleOverlays();
          if (!overlays.length) return;

          const overlayBottom = Math.max(...overlays.map(el => el.getBoundingClientRect().bottom));
          const offset = Math.ceil(overlayBottom + 12);
          const container = findContentContainer(root, overlayBottom);
          if (!container) return;

          if (container.getAttribute(OFFSET_ATTR) !== String(offset)) {
            container.style.paddingTop = `${offset}px`;
            container.setAttribute(OFFSET_ATTR, String(offset));
          }
        }

        const observer = new MutationObserver(() => {
          window.requestAnimationFrame(applyCmsOffset);
        });

        window.addEventListener("load", () => {
          const root = document.getElementById("nc-root");
          if (!root) return;
          observer.observe(root, { childList: true, subtree: true, attributes: true });
          applyCmsOffset();
          window.addEventListener("resize", applyCmsOffset, { passive: true });
          setTimeout(applyCmsOffset, 400);
          setTimeout(applyCmsOffset, 1200);
        });
      })();
    </script>
  </head>
  <body>
    <div class="cms-shell">
      <header class="cms-banner">
        <div class="cms-brand">
          <span class="cms-seal">写作</span>
          <div class="cms-title">
            <strong>江南字栈内容后台</strong>
            <span>文章、页面、封面图与图片上传入口</span>
          </div>
        </div>
        <div class="cms-note">登录后可直接在浏览器中写作并发布。</div>
      </header>
      <div id="nc-root"></div>
    </div>
  </body>
</html>
