$bg-deep = #0d1417
$bg-water = #152228
$bg-panel = rgba(11, 19, 23, .78)
$bg-panel-soft = rgba(18, 28, 33, .66)
$bg-paper = rgba(242, 240, 233, .92)
$ink = #d7ded8
$ink-soft = rgba(226, 232, 227, .78)
$ink-dark = #223036
$line = rgba(223, 228, 220, .12)
$line-strong = rgba(236, 232, 221, .18)
$lantern = #cb4c34
$lantern-soft = rgba(203, 76, 52, .24)
$gold = #b79a63
$jade = #7fa19a
$mist = rgba(233, 240, 237, .08)
$shadow = rgba(0, 0, 0, .34)

html, body {
  min-height: 100%;
}

body {
  background:
    radial-gradient(circle at 20% 14%, rgba(87, 113, 102, .2), transparent 22%),
    radial-gradient(circle at 82% 22%, rgba(97, 121, 115, .16), transparent 18%),
    linear-gradient(180deg, rgba(8, 14, 16, .26), rgba(8, 14, 16, .42)),
    linear-gradient(180deg, #10191d 0%, #132229 38%, #0c1619 100%);
  color: $ink;
  font-family: "Noto Serif SC", "Source Han Serif SC", "Songti SC", STFangsong, serif;
}

body::before {
  background:
    radial-gradient(circle at 50% 8%, rgba(255, 255, 255, .08), transparent 18%),
    repeating-linear-gradient(180deg, rgba(255, 255, 255, .02) 0 2px, transparent 2px 26px);
  content: "";
  inset: 0;
  pointer-events: none;
  position: fixed;
  z-index: -2;
}

body::after {
  background: linear-gradient(180deg, rgba(255, 255, 255, .02), rgba(0, 0, 0, .14));
  content: "";
  inset: 0;
  pointer-events: none;
  position: fixed;
  z-index: -1;
}

.use-motion .header,
.use-motion .main-inner,
.use-motion .post-block,
.use-motion .sidebar,
.use-motion .sidebar-inner,
.use-motion .post-header,
.use-motion .post-body,
.use-motion .pagination,
.use-motion .comments,
.use-motion .collection-header,
.use-motion .footer,
.use-motion .menu-item,
.use-motion .site-title,
.use-motion .site-subtitle,
.use-motion .custom-logo-image,
.use-motion .column {
  opacity: 1 !important;
  visibility: visible !important;
}

a {
  color: #e6dac0;
}

a:hover {
  color: #f4e7c7;
}

.headband {
  background: linear-gradient(90deg, transparent, rgba(203, 76, 52, .8), transparent);
  box-shadow: 0 10px 30px rgba(203, 76, 52, .18);
  height: 6px;
}

.header {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, .05);
  border-radius: 30px;
  box-shadow: 0 32px 80px rgba(0, 0, 0, .26);
  margin-bottom: 28px;
  margin-top: 28px;
  overflow: hidden;
  position: relative;
}

.header::before {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, .05), transparent 16%),
    linear-gradient(180deg, transparent 70%, rgba(0, 0, 0, .26));
  content: "";
  inset: 0;
  pointer-events: none;
  position: absolute;
  z-index: 0;
}

.site-brand-container,
.site-nav {
  position: relative;
  z-index: 2;
}

.site-brand-container {
  backdrop-filter: blur(8px);
  background: linear-gradient(180deg, rgba(8, 14, 16, .58), rgba(8, 14, 16, .2));
  padding: 28px 34px 18px;
}

.site-meta {
  text-align: center;
}

.brand {
  color: #f2efe8 !important;
}

.site-title {
  color: #f8f4ea;
  font-size: 38px;
  font-weight: 600;
  letter-spacing: .24em;
  text-shadow: 0 18px 34px rgba(0, 0, 0, .35);
}

.site-subtitle {
  color: rgba(237, 239, 231, .78);
  display: block;
  font-size: 13px;
  letter-spacing: .36em;
  margin-top: 12px;
}

.logo-line {
  background: linear-gradient(90deg, transparent, rgba(233, 220, 190, .9), transparent) !important;
  height: 1px;
  width: 110px;
}

.site-nav {
  backdrop-filter: blur(14px);
  background: linear-gradient(180deg, rgba(8, 14, 16, .44), rgba(8, 14, 16, .3));
  border-top: 1px solid rgba(255, 255, 255, .06);
  padding: 14px 22px 20px;
}

.main-menu {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
}

.menu-item a,
.menu-item-search a {
  background: rgba(250, 246, 237, .08);
  border: 1px solid rgba(255, 255, 255, .08);
  border-radius: 999px;
  color: #f3ece2 !important;
  padding: 10px 18px;
  transition: all .24s ease;
}

.menu-item a:hover,
.menu-item-search a:hover,
.menu-item-active a {
  background: rgba(203, 76, 52, .18);
  border-color: rgba(239, 214, 162, .24);
  box-shadow: 0 12px 28px rgba(0, 0, 0, .18);
}

.jiangnan-hero {
  background:
    linear-gradient(90deg, rgba(7, 13, 16, .72) 0%, rgba(7, 13, 16, .58) 36%, rgba(7, 13, 16, .18) 100%),
    linear-gradient(180deg, rgba(13, 20, 23, .14), rgba(13, 20, 23, .44)),
    url("/images/jiangnan/hero-night.jpg");
  background-position: center center;
  background-size: cover;
  display: grid;
  gap: 28px;
  grid-template-columns: minmax(0, 1.1fr) minmax(260px, .9fr);
  min-height: 460px;
  padding: 54px 42px 34px;
  position: relative;
}

.jiangnan-hero::before {
  background:
    radial-gradient(circle at 78% 30%, rgba(255, 214, 158, .14), transparent 14%),
    radial-gradient(circle at 84% 76%, rgba(186, 206, 215, .12), transparent 20%),
    linear-gradient(180deg, rgba(236, 240, 241, .05), rgba(0, 0, 0, 0));
  content: "";
  inset: 0;
  pointer-events: none;
  position: absolute;
}

.jiangnan-hero::after {
  background:
    linear-gradient(180deg, transparent, rgba(10, 16, 18, .62)),
    repeating-linear-gradient(180deg, rgba(255, 255, 255, .03) 0 2px, transparent 2px 22px);
  content: "";
  inset: 0;
  pointer-events: none;
  position: absolute;
}

.jiangnan-hero-copy,
.jiangnan-scene {
  position: relative;
  z-index: 1;
}

.jiangnan-hero-copy {
  align-self: center;
  color: #f7f3ea;
  max-width: 620px;
}

.jiangnan-seal {
  background: linear-gradient(180deg, #a22d1f, #7b1f14);
  border: 1px solid rgba(255, 221, 205, .18);
  border-radius: 12px;
  box-shadow: 0 10px 24px rgba(89, 20, 12, .28);
  color: #fff2e8;
  display: inline-flex;
  font-size: 15px;
  letter-spacing: .34em;
  margin-bottom: 18px;
  padding: 10px 12px 10px 16px;
}

.jiangnan-hero-kicker {
  color: rgba(235, 240, 237, .72);
  font-size: 12px;
  letter-spacing: .42em;
  margin: 0 0 14px;
  text-transform: uppercase;
}

.jiangnan-hero-title {
  color: #f6f0e4;
  font-size: 48px;
  font-weight: 600;
  letter-spacing: .08em;
  line-height: 1.2;
  margin: 0 0 18px;
  text-shadow: 0 18px 34px rgba(0, 0, 0, .42);
}

.jiangnan-hero-poem {
  color: rgba(229, 220, 197, .82);
  font-size: 15px;
  letter-spacing: .12em;
  line-height: 1.9;
  margin: -4px 0 16px;
}

.jiangnan-hero-desc {
  color: rgba(236, 240, 233, .84);
  font-size: 16px;
  line-height: 2;
  margin: 0;
  max-width: 580px;
}

.jiangnan-hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;
}

.jiangnan-hero-meta span {
  background: rgba(255, 246, 230, .08);
  border: 1px solid rgba(255, 246, 230, .12);
  border-radius: 999px;
  color: rgba(246, 239, 227, .88);
  font-size: 12px;
  letter-spacing: .12em;
  padding: 8px 14px;
}

.jiangnan-hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-top: 28px;
}

.jiangnan-hero-link {
  background: linear-gradient(135deg, rgba(241, 232, 211, .94), rgba(229, 217, 193, .9));
  border: 1px solid rgba(255, 250, 244, .2);
  border-radius: 999px;
  box-shadow: 0 16px 28px rgba(0, 0, 0, .22);
  color: #182327 !important;
  display: inline-flex;
  font-size: 14px;
  letter-spacing: .08em;
  padding: 12px 22px;
}

.jiangnan-hero-link.is-ghost {
  background: rgba(255, 248, 236, .08);
  border-color: rgba(255, 248, 236, .16);
  color: #f7f0e3 !important;
}

.jiangnan-hero-link.is-admin {
  background: linear-gradient(135deg, rgba(136, 41, 29, .96), rgba(190, 95, 58, .92));
  border-color: rgba(255, 232, 203, .18);
  color: #fff6ed !important;
}

.jiangnan-hero-link.is-admin:hover {
  background: linear-gradient(135deg, rgba(158, 50, 36, .96), rgba(208, 112, 73, .94));
}

.jiangnan-scene {
  align-self: end;
  min-height: 320px;
}

.jiangnan-scene::before {
  background:
    radial-gradient(circle at 64% 18%, rgba(255, 228, 173, .28), transparent 8%),
    radial-gradient(circle at 76% 24%, rgba(255, 207, 135, .22), transparent 12%),
    radial-gradient(circle at 88% 80%, rgba(135, 168, 179, .14), transparent 20%);
  content: "";
  inset: 0;
  position: absolute;
}

.jiangnan-scene::after {
  background:
    linear-gradient(180deg, transparent 0%, rgba(4, 9, 11, .12) 48%, rgba(4, 9, 11, .62) 100%),
    radial-gradient(ellipse at 70% 88%, rgba(203, 76, 52, .12), transparent 18%);
  content: "";
  inset: 0;
  position: absolute;
}

.main {
  padding-bottom: 52px;
}

.main-inner {
  background: rgba(6, 11, 13, .24);
  border: 1px solid rgba(255, 255, 255, .04);
  border-radius: 30px;
  box-shadow: 0 32px 80px rgba(0, 0, 0, .22);
  padding: 30px 24px 40px;
}

.sidebar-inner {
  background: $bg-panel-soft;
  border: 1px solid $line;
  border-radius: 24px;
  box-shadow: 0 22px 48px rgba(0, 0, 0, .18);
  color: $ink;
  padding: 22px 18px;
  backdrop-filter: blur(10px);
  position: relative;
}

.sidebar-inner::before {
  background: linear-gradient(180deg, rgba(255, 244, 222, .24), transparent);
  content: "";
  height: 54px;
  left: 18px;
  position: absolute;
  top: 0;
  width: 1px;
}

.sidebar-nav {
  border-bottom: 1px solid rgba(255, 255, 255, .08);
  margin-bottom: 14px;
  padding-bottom: 12px;
}

.sidebar-nav li,
.site-description,
.site-state-item-name {
  color: $ink-soft;
}

.site-author-name,
.site-state-item-count {
  color: #f7f3ea;
}

.site-state-item {
  background: rgba(255, 255, 255, .04);
  border: 1px solid rgba(255, 255, 255, .06);
  border-radius: 16px;
  margin: 0 4px;
  padding: 12px 8px;
}

.post-block,
.pagination,
.comments {
  background:
    linear-gradient(180deg, rgba(247, 243, 235, .96), rgba(241, 237, 229, .94));
  border: 1px solid rgba(255, 255, 255, .32);
  border-radius: 26px;
  box-shadow: 0 18px 44px rgba(0, 0, 0, .18);
  margin-bottom: 26px;
  overflow: hidden;
  padding: 10px 4px;
  position: relative;
  transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
}

.post-block::before {
  background: linear-gradient(90deg, rgba(203, 76, 52, .96), rgba(183, 154, 99, .78), transparent);
  content: "";
  display: block;
  height: 4px;
}

.post-block::after,
.pagination::after,
.comments::after {
  border: 1px solid rgba(80, 96, 102, .08);
  border-radius: 20px;
  content: "";
  inset: 12px;
  pointer-events: none;
  position: absolute;
}

.post-block:hover {
  border-color: rgba(194, 172, 123, .42);
  box-shadow: 0 24px 54px rgba(0, 0, 0, .22);
  transform: translateY(-4px);
}

.posts-expand .post-header,
.posts-expand .post-body,
.posts-expand .post-footer {
  padding-left: 28px;
  padding-right: 28px;
}

.post-title {
  font-size: 30px;
  font-weight: 600;
  letter-spacing: .06em;
  margin-top: 8px;
}

.post-title-link,
.post-body h1,
.post-body h2,
.post-body h3,
.post-body h4 {
  color: $ink-dark !important;
}

.post-meta {
  color: rgba(55, 69, 73, .74);
  letter-spacing: .03em;
}

.post-meta-item-icon {
  color: $lantern;
}

.post-body {
  color: #2f3d43;
  font-size: 16px;
  line-height: 2.04;
}

.post-body h2 {
  border-left: 4px solid rgba(183, 154, 99, .9);
  margin-top: 2.2em;
  padding-left: 14px;
  position: relative;
}

.post-body h2::after {
  background: linear-gradient(90deg, rgba(183, 154, 99, .34), transparent);
  content: "";
  height: 1px;
  left: 14px;
  position: absolute;
  right: 0;
  top: calc(100% + 10px);
}

.post-body blockquote {
  background: linear-gradient(135deg, rgba(217, 228, 230, .78), rgba(244, 239, 230, .98));
  border-left: 0;
  border-radius: 18px;
  color: #41535b;
  margin: 1.8em 0;
  padding: 18px 22px;
  position: relative;
}

.post-body blockquote::before {
  color: rgba(183, 154, 99, .38);
  content: "\6C34";
  font-size: 44px;
  left: 18px;
  line-height: 1;
  position: absolute;
  top: 10px;
}

.post-body blockquote p {
  margin-left: 28px;
}

.highlight,
pre,
code {
  font-family: "JetBrains Mono", Consolas, "Liberation Mono", monospace;
}

.highlight {
  border: 1px solid rgba(22, 38, 44, .08);
  border-radius: 18px;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, .36);
  overflow: hidden;
}

.highlight .gutter {
  background: rgba(219, 227, 224, .92) !important;
}

.highlight .code {
  background: rgba(243, 246, 245, .98) !important;
}

.article .post-button {
  margin-top: 24px;
}

.btn {
  background: linear-gradient(135deg, #7b2217, #b65435);
  border: 0;
  border-radius: 999px;
  box-shadow: 0 14px 24px rgba(127, 35, 23, .24);
  color: #fff !important;
  padding: 10px 22px;
}

.btn:hover {
  background: linear-gradient(135deg, #9a3424, #c96c47);
}

.pagination .page-number,
.pagination .extend {
  background: rgba(255, 255, 255, .82);
  border: 1px solid rgba(62, 79, 85, .12);
  border-radius: 999px;
  margin: 0 6px;
  min-width: 42px;
}

.footer {
  color: rgba(230, 235, 231, .76);
  margin-top: 28px;
}

.footer-inner {
  background: rgba(10, 17, 20, .56);
  border: 1px solid rgba(255, 255, 255, .05);
  border-radius: 22px;
  box-shadow: 0 20px 48px rgba(0, 0, 0, .18);
  padding: 20px 26px;
}

.back-to-top,
.sidebar-toggle {
  background: linear-gradient(135deg, #7b2317, #bc5b38) !important;
  border-radius: 18px !important;
  box-shadow: 0 16px 28px rgba(0, 0, 0, .22);
  color: #fff !important;
}

.reading-progress-bar {
  background: linear-gradient(90deg, #bc5b38, #cba66e);
}

.search-popup {
  background: rgba(15, 24, 29, .94);
  border: 1px solid rgba(255, 255, 255, .08);
  border-radius: 24px;
  box-shadow: 0 26px 56px rgba(0, 0, 0, .28);
  color: $ink;
}

.search-input {
  background: transparent;
  color: $ink;
}

.search-result-title,
.search-result {
  color: $ink;
}

.about-page-cover,
.post-page-cover {
  border-radius: 22px;
  box-shadow: 0 22px 46px rgba(0, 0, 0, .18);
  margin: 0 auto 28px;
  overflow: hidden;
  position: relative;
}

.about-page-cover img,
.post-page-cover img {
  display: block;
  width: 100%;
}

.about-page-cover::after,
.post-page-cover::after {
  border: 1px solid rgba(255, 255, 255, .34);
  border-radius: 18px;
  content: "";
  inset: 12px;
  pointer-events: none;
  position: absolute;
}

.jiangnan-inscription {
  align-items: center;
  background: linear-gradient(135deg, rgba(225, 233, 231, .62), rgba(245, 240, 231, .96));
  border-left: 3px solid rgba(183, 154, 99, .86);
  border-radius: 18px;
  display: flex;
  gap: 14px;
  margin: 0 0 28px;
  padding: 16px 20px;
}

.jiangnan-inscription-label {
  background: linear-gradient(180deg, #8a2a1d, #6e1f15);
  border-radius: 10px;
  color: #fff2e8;
  display: inline-flex;
  font-size: 12px;
  letter-spacing: .28em;
  padding: 8px 10px 8px 14px;
  white-space: nowrap;
}

.jiangnan-inscription p {
  color: #41535b;
  margin: 0;
}

@media (max-width: 991px) {
  .header {
    margin-top: 18px;
  }

  .site-brand-container {
    padding: 22px 18px 14px;
  }

  .site-title {
    font-size: 26px;
    letter-spacing: .16em;
  }

  .site-subtitle {
    font-size: 12px;
    letter-spacing: .24em;
  }

  .jiangnan-hero {
    grid-template-columns: 1fr;
    min-height: 420px;
    padding: 30px 18px 24px;
  }

  .jiangnan-hero-title {
    font-size: 32px;
  }

  .jiangnan-hero-poem {
    font-size: 14px;
    line-height: 1.8;
  }

  .jiangnan-hero-desc {
    font-size: 15px;
    line-height: 1.9;
  }

  .jiangnan-scene {
    min-height: 120px;
  }

  .main-inner {
    border-radius: 24px;
    padding: 18px 10px 24px;
  }

  .posts-expand .post-header,
  .posts-expand .post-body,
  .posts-expand .post-footer {
    padding-left: 18px;
    padding-right: 18px;
  }

  .post-title {
    font-size: 24px;
  }

  .jiangnan-inscription {
    align-items: flex-start;
    flex-direction: column;
    gap: 10px;
  }
}
