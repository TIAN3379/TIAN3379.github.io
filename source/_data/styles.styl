$ink = #27433a
$ink-soft = #4f6b60
$mist = #eef4ee
$paper = #fbf8f1
$paper-strong = #f6f0e4
$line = rgba(64, 89, 75, .16)
$gold = #9f7a3f
$pond = #dceae0
$shadow = rgba(37, 54, 44, .08)

html, body {
  min-height: 100%;
}

body {
  background:
    radial-gradient(circle at 14% 18%, rgba(179, 204, 187, .22), transparent 24%),
    radial-gradient(circle at 82% 12%, rgba(154, 183, 167, .18), transparent 20%),
    radial-gradient(circle at 75% 78%, rgba(188, 205, 194, .18), transparent 22%),
    linear-gradient(180deg, rgba(255, 255, 255, .72), rgba(255, 255, 255, .72)),
    linear-gradient(135deg, #f5f0e4 0%, #fbfaf6 38%, #eef4ee 100%);
  color: $ink;
  font-family: "Noto Serif SC", "Source Han Serif SC", "Songti SC", STFangsong, serif;
}

body::before {
  background:
    linear-gradient(to right, transparent 0, transparent 48%, rgba(140, 162, 147, .08) 50%, transparent 52%, transparent 100%),
    linear-gradient(to bottom, transparent 0, transparent 48%, rgba(140, 162, 147, .07) 50%, transparent 52%, transparent 100%);
  background-size: 160px 160px;
  content: "";
  inset: 0;
  opacity: .45;
  pointer-events: none;
  position: fixed;
  z-index: -2;
}

body::after {
  background:
    radial-gradient(circle at 20% 20%, rgba(255, 255, 255, .8), transparent 18%),
    radial-gradient(circle at 80% 30%, rgba(255, 255, 255, .45), transparent 20%);
  content: "";
  inset: 0;
  pointer-events: none;
  position: fixed;
  z-index: -1;
}

.use-motion .header,
.use-motion .main-inner,
.use-motion .post-block,
.use-motion .sidebar,
.use-motion .sidebar-inner,
.use-motion .post-header,
.use-motion .post-body,
.use-motion .pagination,
.use-motion .comments,
.use-motion .collection-header,
.use-motion .footer,
.use-motion .menu-item,
.use-motion .site-title,
.use-motion .site-subtitle,
.use-motion .custom-logo-image,
.use-motion .column {
  opacity: 1 !important;
  visibility: visible !important;
}

a {
  color: $ink-soft;
}

a:hover {
  color: $gold;
}

.headband {
  background: linear-gradient(90deg, rgba(39, 67, 58, .9), rgba(159, 122, 63, .62), rgba(39, 67, 58, .9));
  box-shadow: 0 12px 28px rgba(39, 67, 58, .12);
  height: 8px;
}

.header {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(255, 255, 255, .72)),
    linear-gradient(135deg, rgba(220, 234, 224, .48), rgba(255, 255, 255, .15));
  border: 1px solid rgba(255, 255, 255, .42);
  border-radius: 30px;
  box-shadow: 0 22px 60px $shadow;
  margin-bottom: 28px;
  margin-top: 36px;
  overflow: hidden;
  position: relative;
}

.header::before {
  background:
    radial-gradient(circle at 15% 30%, rgba(159, 122, 63, .08), transparent 24%),
    radial-gradient(circle at 78% 12%, rgba(57, 96, 77, .08), transparent 20%),
    linear-gradient(90deg, transparent, rgba(63, 92, 80, .06), transparent);
  content: "";
  inset: 0;
  pointer-events: none;
  position: absolute;
}

.site-brand-container {
  background: linear-gradient(180deg, rgba(248, 244, 235, .88), rgba(255, 255, 255, .2));
  padding: 34px 42px 22px;
}

.site-meta {
  text-align: center;
}

.brand {
  color: $ink !important;
}

.site-title {
  color: $ink;
  font-size: 34px;
  font-weight: 600;
  letter-spacing: .22em;
  text-shadow: 0 8px 20px rgba(69, 103, 86, .08);
}

.site-subtitle {
  color: $ink-soft;
  display: block;
  font-size: 14px;
  letter-spacing: .35em;
  margin-top: 12px;
  opacity: .95;
}

.logo-line {
  background: linear-gradient(90deg, transparent, rgba(159, 122, 63, .85), transparent) !important;
  height: 1px;
  width: 96px;
}

.site-nav {
  background: rgba(248, 244, 235, .78);
  border-top: 1px solid rgba(159, 122, 63, .12);
  padding: 14px 24px 18px;
}

.jiangnan-hero {
  background:
    radial-gradient(circle at 72% 24%, rgba(244, 247, 241, .26), transparent 18%),
    linear-gradient(180deg, rgba(22, 38, 33, .08), rgba(22, 38, 33, .02)),
    linear-gradient(135deg, #20332d 0%, #2d443c 26%, #446458 52%, #87a7a2 82%, #edf2ea 100%);
  display: grid;
  gap: 32px;
  grid-template-columns: minmax(0, 1.1fr) minmax(280px, .9fr);
  overflow: hidden;
  padding: 42px 42px 30px;
  position: relative;
}

.jiangnan-hero::before {
  background:
    radial-gradient(circle at 12% 24%, rgba(145, 169, 123, .36), transparent 20%),
    radial-gradient(circle at 88% 10%, rgba(255, 255, 255, .12), transparent 18%),
    linear-gradient(180deg, rgba(7, 17, 16, 0), rgba(7, 17, 16, .28));
  content: "";
  inset: 0;
  pointer-events: none;
  position: absolute;
}

.jiangnan-hero-copy,
.jiangnan-scene {
  position: relative;
  z-index: 1;
}

.jiangnan-hero-copy {
  align-self: center;
  color: rgba(248, 245, 237, .96);
  max-width: 620px;
}

.jiangnan-seal {
  background: linear-gradient(180deg, #a6372b, #7f2218);
  border-radius: 14px;
  box-shadow: 0 10px 24px rgba(99, 22, 12, .28);
  color: #fff7ed;
  display: inline-flex;
  font-size: 15px;
  letter-spacing: .38em;
  margin-bottom: 18px;
  padding: 12px 14px 12px 18px;
}

.jiangnan-hero-kicker {
  color: rgba(240, 240, 233, .72);
  font-size: 12px;
  letter-spacing: .42em;
  margin: 0 0 14px;
  text-transform: uppercase;
}

.jiangnan-hero-title {
  color: #f7f2e8;
  font-size: 46px;
  font-weight: 600;
  letter-spacing: .08em;
  line-height: 1.25;
  margin: 0 0 18px;
  text-shadow: 0 16px 36px rgba(7, 17, 16, .36);
}

.jiangnan-hero-desc {
  color: rgba(243, 242, 236, .82);
  font-size: 16px;
  line-height: 2.05;
  margin: 0;
  max-width: 560px;
}

.jiangnan-hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-top: 28px;
}

.jiangnan-hero-link {
  background: linear-gradient(135deg, rgba(255, 248, 237, .96), rgba(219, 232, 224, .94));
  border: 1px solid rgba(255, 255, 255, .2);
  border-radius: 999px;
  box-shadow: 0 14px 28px rgba(12, 29, 26, .18);
  color: #203a31 !important;
  display: inline-flex;
  font-size: 14px;
  gap: 8px;
  letter-spacing: .08em;
  padding: 12px 22px;
}

.jiangnan-hero-link:hover {
  transform: translateY(-1px);
}

.jiangnan-hero-link.is-ghost {
  background: rgba(255, 255, 255, .08);
  border-color: rgba(255, 255, 255, .18);
  color: #f7f2e8 !important;
}

.jiangnan-scene {
  align-self: end;
  min-height: 330px;
}

.jiangnan-scene-sky {
  background:
    radial-gradient(circle at 78% 12%, rgba(255, 255, 255, .3), transparent 18%),
    linear-gradient(180deg, rgba(226, 236, 226, .14), rgba(91, 124, 117, 0));
  inset: 0;
  position: absolute;
}

.jiangnan-moon-gate {
  border: 14px solid rgba(242, 236, 224, .88);
  border-radius: 50%;
  height: 270px;
  position: absolute;
  right: 8%;
  top: 6%;
  width: 270px;
}

.jiangnan-moon-gate::before {
  background: radial-gradient(circle at 50% 44%, rgba(233, 240, 242, .34), rgba(111, 146, 151, .08) 62%, transparent 72%);
  border-radius: 50%;
  content: "";
  inset: 18px;
  position: absolute;
}

.jiangnan-bridge {
  border: 10px solid rgba(218, 211, 196, .9);
  border-bottom: 0;
  border-radius: 220px 220px 0 0;
  height: 130px;
  left: 36%;
  position: absolute;
  top: 28%;
  transform: translateX(-20%);
  width: 240px;
}

.jiangnan-house,
.jiangnan-house.second {
  background: linear-gradient(180deg, rgba(18, 24, 22, .96), rgba(37, 46, 43, .9));
  bottom: 104px;
  box-shadow: 0 18px 24px rgba(11, 18, 17, .16);
  position: absolute;
}

.jiangnan-house {
  border-radius: 14px 14px 0 0;
  height: 150px;
  left: 0;
  width: 120px;
}

.jiangnan-house::before,
.jiangnan-house.second::before {
  background: linear-gradient(180deg, #131716, #0e1110);
  clip-path: polygon(0 100%, 12% 28%, 82% 0, 100% 100%);
  content: "";
  height: 52px;
  left: -8px;
  position: absolute;
  right: -10px;
  top: -26px;
}

.jiangnan-house.second {
  height: 118px;
  left: 92px;
  opacity: .88;
  width: 84px;
}

.jiangnan-lanterns {
  display: flex;
  gap: 12px;
  left: 54px;
  position: absolute;
  top: 120px;
}

.jiangnan-lanterns span,
.jiangnan-boat-lantern {
  background: radial-gradient(circle at 50% 40%, #ff7962, #bc2319 78%);
  border-radius: 50% 50% 44% 44%;
  box-shadow: 0 0 16px rgba(255, 108, 80, .38);
  display: block;
  height: 22px;
  position: relative;
  width: 18px;
}

.jiangnan-lanterns span::after,
.jiangnan-boat-lantern::after {
  background: rgba(255, 220, 178, .86);
  border-radius: 999px;
  content: "";
  height: 2px;
  left: 4px;
  position: absolute;
  right: 4px;
  top: 8px;
}

.jiangnan-boat {
  background: linear-gradient(180deg, rgba(23, 31, 30, .96), rgba(12, 17, 16, .96));
  border-radius: 60% 40% 45% 55% / 80% 80% 20% 20%;
  bottom: 64px;
  box-shadow: 0 22px 34px rgba(13, 21, 20, .28);
  height: 24px;
  left: 56%;
  position: absolute;
  width: 78px;
}

.jiangnan-boat::before {
  background: linear-gradient(180deg, rgba(16, 22, 21, .82), rgba(66, 85, 78, .18));
  border-radius: 4px;
  content: "";
  height: 38px;
  left: 30px;
  position: absolute;
  top: -30px;
  width: 10px;
}

.jiangnan-boat-lantern {
  height: 12px;
  position: absolute;
  top: -6px;
  width: 10px;
}

.jiangnan-boat-lantern.left {
  left: 16px;
}

.jiangnan-boat-lantern.right {
  right: 16px;
}

.jiangnan-water {
  background:
    linear-gradient(180deg, rgba(173, 206, 216, .14), transparent 18%),
    linear-gradient(180deg, rgba(120, 156, 160, .88), rgba(91, 120, 126, .92) 42%, rgba(58, 82, 91, .96) 100%);
  bottom: -8px;
  height: 118px;
  left: -20px;
  position: absolute;
  right: -20px;
}

.jiangnan-water::before {
  background:
    repeating-linear-gradient(180deg, rgba(226, 238, 242, .2) 0 2px, transparent 2px 18px),
    repeating-linear-gradient(90deg, rgba(255, 255, 255, .06) 0 32px, transparent 32px 64px);
  content: "";
  inset: 0;
  opacity: .7;
  position: absolute;
}

.jiangnan-reflection {
  background:
    radial-gradient(circle at 56% 18%, rgba(255, 255, 255, .25), transparent 12%),
    linear-gradient(180deg, rgba(255, 98, 82, .12), transparent 28%),
    linear-gradient(180deg, rgba(15, 21, 20, .18), transparent 45%);
  bottom: 0;
  height: 92px;
  left: 18%;
  opacity: .66;
  position: absolute;
  right: 6%;
}

.main-menu {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  justify-content: center;
}

.menu-item a,
.menu-item-search a {
  background: rgba(255, 255, 255, .54);
  border: 1px solid rgba(80, 108, 94, .14);
  border-radius: 999px;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, .65);
  color: $ink !important;
  padding: 10px 18px;
  transition: all .24s ease;
}

.menu-item a:hover,
.menu-item-search a:hover,
.menu-item-active a {
  background: linear-gradient(135deg, rgba(219, 233, 223, .94), rgba(255, 249, 239, .95));
  border-color: rgba(159, 122, 63, .26);
  box-shadow: 0 10px 24px rgba(39, 67, 58, .08);
  transform: translateY(-1px);
}

.main {
  padding-bottom: 48px;
}

.main-inner {
  background: rgba(255, 252, 246, .62);
  border: 1px solid rgba(255, 255, 255, .5);
  border-radius: 32px;
  box-shadow: 0 32px 72px $shadow;
  padding: 34px 26px 42px;
}

.sidebar {
  margin-left: 0;
}

.sidebar-inner {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(244, 239, 230, .84));
  border: 1px solid $line;
  border-radius: 28px;
  box-shadow: 0 20px 48px $shadow;
  padding: 24px 20px;
}

.sidebar-nav {
  border-bottom: 1px solid rgba(159, 122, 63, .16);
  margin-bottom: 16px;
  padding-bottom: 12px;
}

.sidebar-nav li {
  color: $ink-soft;
  font-size: 13px;
  letter-spacing: .18em;
  text-transform: uppercase;
}

.site-author-name {
  color: $ink;
  font-size: 22px;
  letter-spacing: .12em;
}

.site-description {
  color: $ink-soft;
  font-size: 14px;
  line-height: 2;
  margin-top: 10px;
}

.site-state {
  margin-top: 18px;
}

.site-state-item {
  background: rgba(237, 244, 238, .74);
  border: 1px solid rgba(80, 108, 94, .12);
  border-radius: 18px;
  margin: 0 4px;
  padding: 12px 8px;
}

.post-block,
.pagination,
.comments {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(250, 247, 240, .95));
  border: 1px solid rgba(88, 116, 101, .12);
  border-radius: 28px;
  box-shadow: 0 18px 42px rgba(42, 63, 51, .07);
  margin-bottom: 26px;
  overflow: hidden;
  padding: 10px 4px;
}

.post-block::before {
  background: linear-gradient(90deg, rgba(39, 67, 58, .9), rgba(159, 122, 63, .35), transparent);
  content: "";
  display: block;
  height: 4px;
}

.posts-expand .post-header,
.posts-expand .post-body,
.posts-expand .post-footer {
  padding-left: 28px;
  padding-right: 28px;
}

.post-title {
  font-size: 30px;
  font-weight: 600;
  letter-spacing: .06em;
}

.post-title-link {
  color: $ink !important;
}

.post-meta {
  color: rgba(71, 92, 82, .82);
}

.post-meta-item-icon {
  color: $gold;
}

.post-body {
  color: #34463f;
  font-size: 16px;
  line-height: 2.05;
}

.post-body h1,
.post-body h2,
.post-body h3,
.post-body h4 {
  color: $ink;
  font-weight: 600;
  letter-spacing: .06em;
}

.post-body h2 {
  border-left: 4px solid rgba(159, 122, 63, .7);
  margin-top: 2.4em;
  padding-left: 14px;
}

.post-body blockquote {
  background: linear-gradient(135deg, rgba(220, 234, 224, .7), rgba(251, 248, 241, .96));
  border-left: 0;
  border-radius: 18px;
  color: $ink-soft;
  margin: 1.8em 0;
  padding: 18px 22px;
  position: relative;
}

.post-body blockquote::before {
  color: rgba(159, 122, 63, .3);
  content: "\6C34";
  font-size: 46px;
  left: 18px;
  line-height: 1;
  position: absolute;
  top: 10px;
}

.post-body blockquote p {
  margin-left: 28px;
}

.highlight,
pre,
code {
  font-family: "JetBrains Mono", Consolas, "Liberation Mono", monospace;
}

.highlight {
  border: 1px solid rgba(67, 100, 84, .12);
  border-radius: 20px;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, .4);
  overflow: hidden;
}

.highlight .gutter {
  background: rgba(227, 235, 230, .92) !important;
}

.highlight .code {
  background: rgba(246, 249, 246, .96) !important;
}

.btn {
  background: linear-gradient(135deg, #2f5144, #577766);
  border: 0;
  border-radius: 999px;
  box-shadow: 0 12px 24px rgba(47, 81, 68, .22);
  color: #fff !important;
  padding: 10px 22px;
}

.btn:hover {
  background: linear-gradient(135deg, #3f6757, #7e8f60);
}

.pagination .page-number,
.pagination .extend {
  background: rgba(255, 255, 255, .8);
  border: 1px solid rgba(80, 108, 94, .14);
  border-radius: 999px;
  margin: 0 6px;
  min-width: 42px;
}

.footer {
  color: $ink-soft;
  margin-top: 30px;
}

.footer-inner {
  background: rgba(255, 252, 246, .64);
  border: 1px solid rgba(255, 255, 255, .48);
  border-radius: 24px;
  box-shadow: 0 20px 48px $shadow;
  margin: 0 auto 24px;
  padding: 24px 28px;
}

.back-to-top,
.sidebar-toggle {
  background: linear-gradient(135deg, #2c4c3f, #5b7555) !important;
  border-radius: 18px !important;
  box-shadow: 0 16px 28px rgba(39, 67, 58, .22);
  color: #fff !important;
}

.reading-progress-bar {
  background: linear-gradient(90deg, #8fa885, #c6a76c);
}

.search-popup {
  background: rgba(255, 251, 245, .96);
  border: 1px solid rgba(78, 105, 91, .12);
  border-radius: 24px;
  box-shadow: 0 26px 56px rgba(39, 67, 58, .18);
}

.search-input {
  background: transparent;
  color: $ink;
}

@media (max-width: 991px) {
  .header {
    margin-top: 18px;
  }

  .jiangnan-hero {
    gap: 20px;
    grid-template-columns: 1fr;
    padding: 28px 18px 22px;
  }

  .jiangnan-hero-title {
    font-size: 30px;
  }

  .jiangnan-hero-desc {
    font-size: 15px;
    line-height: 1.9;
  }

  .jiangnan-scene {
    min-height: 240px;
  }

  .jiangnan-moon-gate {
    height: 180px;
    right: 4%;
    top: 8%;
    width: 180px;
  }

  .jiangnan-bridge {
    height: 82px;
    top: 34%;
    width: 160px;
  }

  .site-brand-container {
    padding: 24px 18px 18px;
  }

  .site-title {
    font-size: 24px;
    letter-spacing: .16em;
  }

  .site-subtitle {
    font-size: 12px;
    letter-spacing: .22em;
  }

  .main-inner {
    border-radius: 24px;
    padding: 18px 10px 24px;
  }

  .posts-expand .post-header,
  .posts-expand .post-body,
  .posts-expand .post-footer {
    padding-left: 18px;
    padding-right: 18px;
  }

  .post-title {
    font-size: 24px;
  }
}
